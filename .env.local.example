# Copy this file to .env.local and fill in real values. Never commit .env.local.

# From https://create.roblox.com/credentials after creating an OAuth 2.0 app
ROBLOX_CLIENT_ID=
ROBLOX_CLIENT_SECRET=

# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=

# Base URL of this site (must match the redirect URI registered with Roblox)
NEXTAUTH_URL=http://localhost:3000

# Discord invite shown on the home page and on paid order confirmations
DISCORD_SUPPORT_LINK=https://discord.gg/yourinvite

# Deep link that launches Roblox straight into the District RP private
# server, used by the "Join Server" button. Format:
# roblox://placeId=<id>&launchData=<url-encoded JSON with your psCode>
ROBLOX_JOIN_LINK=

# Real live player count + online status for the home banner. Get this from
# inside your ERLC private server: open Server Settings (as owner/co-owner)
# > Server API tab > generate/copy the Server Key. Docs:
# https://apidocs.policeroleplay.community/
ERLC_SERVER_KEY=

# Local dev: leave both blank to use a local file database automatically.
# Production (Vercel etc.): create a free database with the Turso CLI and
# paste its values here — see README.md "Deploying for free" section.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# From https://dashboard.stripe.com/apikeys (test mode keys start with sk_test_)
STRIPE_SECRET_KEY=

# Same page as above — the Publishable Key (starts with pk_test_ / pk_live_).
# Safe to expose to the browser; it's what renders the embedded card form.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# From the webhook endpoint you create at https://dashboard.stripe.com/webhooks
# pointing at https://<your-site>/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=

# Discord channel webhook URL (Channel Settings > Integrations > Webhooks)
# where staff get notified the moment an order is paid
DISCORD_ORDER_WEBHOOK_URL=

# Same bot token/server as your District RP Bot project — used to post unban
# review applications with working Approve/Decline buttons (a plain webhook
# can't have interactive buttons; posting via the bot's own identity can)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
