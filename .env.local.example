# Copy this file to .env.local and fill in real values. Never commit .env.local.

# From https://create.roblox.com/credentials after creating an OAuth 2.0 app
ROBLOX_CLIENT_ID=
ROBLOX_CLIENT_SECRET=

# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=

# Base URL of this site (must match the redirect URI registered with Roblox)
NEXTAUTH_URL=http://localhost:3000

# Where checkout sends people to actually pay (edit to your real links)
PAYPAL_LINK=https://paypal.me/yourhandle
DISCORD_SUPPORT_LINK=https://discord.gg/yourinvite

# Real live player count + online status for the home banner. Get this from
# inside your ERLC private server: open Server Settings (as owner/co-owner)
# > Server API tab > generate/copy the Server Key. Docs:
# https://apidocs.policeroleplay.community/
ERLC_SERVER_KEY=

# Local dev: leave both blank to use a local file database automatically.
# Production (Vercel etc.): create a free database with the Turso CLI and
# paste its values here — see README.md "Deploying for free" section.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
